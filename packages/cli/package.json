{
  "name": "@rinhany/cli",
  "version": "0.1.0",
  "description": "Rinhany terminal UI — apresentador, narrador, publico, tema boxe",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@rinhany/core": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.6",
    "typescript": "^5.8.3",
    "vitest": "^3.2.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
